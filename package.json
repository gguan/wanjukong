{
  "name": "wanjukong",
  "version": "0.1.0",
  "private": true,
  "description": "Wanjukong monorepo - Nuxt 3 + NestJS",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:web": "pnpm --filter @wanjukong/web dev",
    "dev:api": "pnpm --filter @wanjukong/api dev",
    "dev:admin": "pnpm --filter @wanjukong/admin dev",
    "build": "pnpm -r run build",
    "lint": "eslint . --ext .ts,.js,.vue",
    "format": "prettier --write \"**/*.{ts,js,vue,json,md}\"",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:generate": "pnpm --filter @wanjukong/api db:generate",
    "db:migrate": "pnpm --filter @wanjukong/api db:migrate",
    "db:seed": "pnpm --filter @wanjukong/api db:seed"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
