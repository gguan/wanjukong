PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wanjukong

# Admin session (required — use a random 64+ character string in production)
SESSION_SECRET=dev-session-secret-change-in-production

# Storefront base URL used in email links
APP_BASE_URL=http://localhost:3000

# Email delivery (optional in local development; if unset, links are logged to console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Tencent Cloud COS (for product image upload)
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=your-bucket-name-1250000000
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_PUBLIC_BASE_URL=https://your-bucket-name-1250000000.cos.ap-guangzhou.myqcloud.com

# Upload lifecycle
UPLOAD_TEMP_EXPIRE_HOURS=24

WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=      # 32字节，微信支付控制台设置
WECHAT_PAY_PRIVATE_KEY=     # 商户私钥 PEM（\n转义）
WECHAT_PAY_CERT_SERIAL=     # 商户证书序列号
WECHAT_PAY_NOTIFY_URL=      # 回调地址，必须公网可达